Model(video_id='7581338896449981718', url='https://www.tiktok.com/@official.politics/video/7581338896449981718', description='Breaking news #nawazsharif #maryamnawaz #shahbazsharif #unfreezemyaccount #viral ', author='official.politics'), VideoModel(video_id='7581882992512077078', url='https://www.tiktok.com/@official.politics/video/7581882992512077078', description='Big news #nawazsharif #maryamnawaz #shahbazsharif #unfreezemyaccount #viral ', author='official.politics'), VideoModel(video_id='7580030370951793942', url='https://www.tiktok.com/@official.politics/video/7580030370951793942', description='Important news #viral #unfreezemyaccount #shahbazsharif #maryamnawaz #nawazsharif ', author='official.politics'), VideoModel(video_id='7580371317052951830', url='https://www.tiktok.com/@tagesschau/video/7580371317052951830', description='Nach wochenlangen Diskussionen in der schwarz-roten Koalition hat der Bundestag das umstrittene Rentenpaket beschlossen. Mit 319 Ja-Stimmen erreichte das neue Gesetz die absolute Mehrheit. Das Paket sieht vor, das Rentenniveau bis 2031 bei 48 Prozent des aktuellen Durchschnittseinkommens festzuschreiben. Dafür müssen zusätzliche Steuermittel in die Rente fließen. Beschlossen wurde zudem die Ausweitung der Mütterrente. #tagesschau #nachrichten #rente #bundestag', author='tagesschau'), VideoModel(video_id='7581097821454028054', url='https://www.tiktok.com/@tagesschau/video/7581097821454028054', description='Im staatlichen Fernsehen haben Soldaten die Absetzung des Präsidenten von Benin verkündet. Regierungsmitglieder des westafrikanischen Landes sagen dagegen, die Lage sei unter Kontrolle. #benin #nachrichten #tagesschau', author='tagesschau'), VideoModel(video_id='7581356031339466006', url='https://www.tiktok.com/@official.politics/video/7581356031339466006', description='Big Breaking news #nawazsharif #maryamnawaz #shahbazsharif #unfreezemyaccount #viral ', author='official.politics'), VideoModel(video_id='7581482146263616790', url='https://www.tiktok.com/@ntv.de/video/7581482146263616790', description='Vier Köpfe, vier Themen, vier Meinungen: Bei "Blome & Pfeffer" wird heute wieder über kontroverse Themen gestritten. 🗣️ Clara Pfeffers Thema diese Woche: Die Regierung hat den Knall nicht gehört. Oder warum ist das Böllern an Silvester immernoch erlaubt? Darüber diskutiert sie mit Co-Host Nikolaus Blome, Buchautor Gabor Steingart und Grünen-Politikerin Franziska Brantner. 👉 Ihr seht unseren neuen Talk am 8.12. um 20.15 und um 23.30 Uhr bei ntv, ntv.de und Youtube. 👉 Oder, nach der Ausstrahlung, wann ihr möchtet, auf ntv.de, Youtube oder RTL+. #ntv #nachrichten #blomeundpfeffer', author='ntv.de'), VideoModel(video_id='7581114057168637206', url='https://www.tiktok.com/@britainbriefed/video/7581114057168637206', description='Putin Issues 72-Hour Ultimatum to UK – Starmer Faces National Crisis! #Putin #Speaker  #ReformUK  #ParliamentDebat #NigelFarage  #Parliament! #KeirStarmer  #primeminister #LabourParty #UKPolitics #Starmer #RachelReeves #PoliticalNews  #houseofcommons #LabourParty  #BritishPolitics #news #uknews #fyp #foryou #PMQs', author='britainbriefed'), VideoModel(video_id='7579766308510731534', url='https://www.tiktok.com/@maddowshow/video/7579766308510731534', description='New Gallup polling shows that Donald Trump is deeply unpopular with the American people, both in general approval and on specific issues. #fyp #news #politics #trump #poll @msnow', author='maddowshow'), VideoModel(video_id='7581627044451175693', url='https://www.tiktok.com/@msnow/video/7581627044451175693', description='During an unrelated Cabinet roundtable, President Trump appeared to deny comments he made last week, saying he would have “no problem” releasing video footage from the September 2 boat strike. Trump also lashed out at the reporter who pressed him about the previous remark, saying, “You are the most obnoxious reporter.” During the interaction, Trump also seemed to indicate that he had seen the footage of the boat strike. #trump #news #politics', author='msnow'), VideoModel(video_id='7581834559977737494', url='https://www.tiktok.com/@gandul_ro/video/7581834559977737494', description='Trump cere alegeri prezidențiale în Ucraina: „A venit momentul”. „Rusia este într-o poziție puternică de negociere”, spune Trump pentru Politico #trump #ukraine #zelesnky #news #gandul', author='gandul_ro'), VideoModel(video_id='7579637863214484758', url='https://www.tiktok.com/@ntv.de/video/7579637863214484758', description='Donald Trumps Kommentare über #Somalia und US-Bürger mit somalischen Wurzeln triefen vor Rassismus und Entmenschlichung. Entsprechend groß ist das Entsetzen bei Politikern außerhalb der republikanischen Partei. 📲 Immer aktuell informiert seid ihr mit der ntv App. #ntv\xa0#nachrichten', author='ntv.de'), VideoModel(video_id='7581850961556065566', url='https://www.tiktok.com/@foxnews/video/7581850961556065566', description='KAROLINE LEAVITT: “The Democrats are the greatest con artists in American politics.” “They are pretending to champion the issue of affordability when they themselves created the worst inflation crisis in a generation.” | @foxandfriends', author='foxnews'), VideoModel(video_id='7581815727246642454', url='https://www.tiktok.com/@itvpolitics/video/7581815727246642454', description='It follows the Ministry of Defence announcing the next steps in its Atlantic Bastion programme, which will aim to protect the seas around the UK from threats. #itvnews ', author='itvpolitics'), VideoModel(video_id='7581841747634916663', url='https://www.tiktok.com/@cnn/video/7581841747634916663', description="The Australian government says it has banned under-16s from social media for their own safety. Now, two teens are fighting the law in court, arguing a right to political expression. CNN's Angus Watson reports. #cnn #news", author='cnn'), VideoModel(video_id='7581363752688307478', url='https://www.tiktok.com/@official.politics/video/7581363752688307478', description='What is this ⁉️#viral #unfreezemyaccount #shahbazsharif #maryamnawaz #nawazsharif ', author='official.politics'), VideoModel(video_id='7579710265609047309', url='https://www.tiktok.com/@newsweek/video/7579710265609047309', description='As #NATO foreign ministers gathered in Brussels, Secretary-General Mark Rutte said #Russia is "testing our deterrence," citing airspace violations, sabotage operations, and spy ships entering NATO waters as evidence of escalating hybrid threats. #newsweek #news', author='newsweek'), VideoModel(video_id='7581593181058387222', url='https://www.tiktok.com/@impuls_politik/video/7581593181058387222', description='Merz entschuldigt sich für die Stadtbild-Debatte #merz #politik #cdu #news #bundestag ', author='impuls_politik'), VideoModel(video_id='7580021426598464790', url='https://www.tiktok.com/@tagesschau/video/7580021426598464790', description='Schreibt eure Fragen an Bundeskanzler Friedrich Merz in die Kommentare! #arena #tagesschau #nachrichten', author='tagesschau'), VideoModel(video_id='7581456095168843030', url='https://www.tiktok.com/@dein_blick_/video/7581456095168843030', description='DAS ENDE DER DEUTSCHEN WIRTSCHAFT! Kolumnist Hans-Ulrich Jörges ist der Ansicht, dass die Regierung von Bundeskanzler Friedrich Merz nicht zu Reformen fähig ist #foruyou #deutschland #news #aktuell #breakingnews #viralvideotiktok #nachrichten #fyp', author='dein_blick_'), VideoModel(video_id='7581085997933317398', url='https://www.tiktok.com/@c4news/video/7581085997933317398', description="The Trump administration's new national security strategy is a 'giant middle finger to Europe', according to Ben Hodges, a former commander of the US Army in Europe. The document, released this week, slams European officials, accusing them of blocking efforts to end the war in Ukraine and appears to reassess the United States' long-standing alliance with the continent. #News #Channel4News #Europe #Trump #Politics", author='c4news'), VideoModel(video_id='7578570399827365142', url='https://www.tiktok.com/@focus_online/video/7578570399827365142', description='Putin spricht von großer Eroberung, die es gar nicht gab 🤦🏻\u200d♂️ #WladimirPutin fordert den #Rückzug der ukrainischen #Truppen aus dem #Donbass und droht damit, neue Gebiete militärisch zu erobern, sollte die #Ukraine sich weigern. Am Donnerstag erklärte er vor #Journalisten, dass die Zahl der besetzten Gebiete immer weiter zunehme. Um dies zu untermauern, berichtete er von militärischen Erfolgen in der Stadt #Komsomolsk. Das einzige Problem: Eine Stadt namens Komsomolsk gibt es gar nicht. Auf X wird #Putin für den #Fauxpas verspottet. #FOCUS #fyp #FOCUSonline #news #russland #ukrainenews #politik', author='focus_online'), VideoModel(video_id='7581442546606361911', url='https://www.tiktok.com/@dailymail/video/7581442546606361911', description="Elon Musk was left fuming at the European Union after it fined X $140 million, claiming the social media platform failed to comply with transparency rules. The EU claimed X was 'breaching its transparency obligations' under the EU's Digital Services Act. The compliance failures included the 'deceptive design' of X's blue verification checkmark, a lack of opacity regarding its advertising and a lack of access to public data for researchers. #news #EU #usa #X", author='dailymail'), VideoModel(video_id='7581725421469846839', url='https://www.tiktok.com/@cnn/video/7581725421469846839', description='In 2016, as then-presidential candidate Donald Trump vowed that US troops would carry out even his most extreme battlefield orders as commander in chief — some of which former military leaders said would be illegal — Pete Hegseth warned that service members had a duty to refuse unlawful orders from a potential President Trump.', author='cnn'), VideoModel(video_id='7581815146532605217', url='https://www.tiktok.com/@zdfheute/video/7581815146532605217', description='Die Fragestellerin ist Medizinstudentin aus NRW. Der Clip ist ein Ausschnitt aus der ARD-Sendung „Die Arena“, die gestern Abend lief. In der Sendung stellte sich Bundeskanzler Friedrich Merz den Fragen von Zuschauer*innen. Im Oktober hatte Merz in Bezug auf die Migrationspolitik der Bundesregierung gesagt: „[…] aber wir haben natürlich immer im Stadtbild noch dieses Problem, und deswegen ist der Bundesinnenminister ja auch dabei, jetzt in sehr großem Umfang auch Rückführungen zu ermöglichen und durchzuführen.“Die Aussage löste eine große Diskussion aus. Viele warfen Merz Rassismus vor. #merz #stadtbild #bundeskanzler #nachrichten', author='zdfheute'), VideoModel(video_id='7483708114584325418', url='https://www.tiktok.com/@msnow/video/7483708114584325418', description="Rachel Maddow breaks down some of the latest Trump administration headlines emphasizing that despite the dramatic news cycle, it's important to pay close attention to the lesser-known stories. “That is where they are trying to seize truly breathtaking authoritarian power…and the courts, for now, are kind of, sort of barely stopping it for now,” she states. #donaldtrump #pambondi #immigration #transgender #education #rights #doj #news #politics", author='msnow'), VideoModel(video_id='7581810708921191702', url='https://www.tiktok.com/@europe_pulse/video/7581810708921191702', description='Last Hours for Europe’s Peace Proposal #eu #politics #geopolitics #security #safety #donaldtrump #news #ukrainewar #putin #unitedkingdom #germany #france  Volodymyr Zelenskyy met UK Prime Minister Keir Starmer, French President Emmanuel Macron and German Chancellor Friedrich Merz in London to finalize Europe’s peace framework for Ukraine.  Kyiv wants the proposal completed by Tuesday evening before it is handed to the United States, which is exploring ways to mediate an end to Russia’s war. Zelenskyy made clear that Ukraine will not accept any territorial concessions.  After London, Zelenskyy travelled to Brussels for follow-up talks with NATO Secretary General Mark Rutte, European Commission President Ursula von der Leyen and European Council President Antonio Costa. The goal: keep NATO, the EU, and Ukraine aligned on air defense, energy support and the political conditions for any future negotiations. ------------------------------------------------------ *Subscribe to Europe Pulse* Stay updated with the latest news from Europe.', author='europe_pulse'), VideoModel(video_id='7581552750341721367', url='https://www.tiktok.com/@tracihogan5/video/7581552750341721367', description='The Blob wants Farage in Gaol #jacobreesmogg #ukpolitics #news #UKnews #UKPolitics #UKSociety #Explained #fyp', author='tracihogan5'), VideoModel(video_id='7581544767993957654', url='https://www.tiktok.com/@itvpolitics/video/7581544767993957654', description='Protestor interrupts debate on digital ID in Parliament #politics  @itvnews ', author='itvpolitics'), VideoModel(video_id='7579284006680726786', url='https://www.tiktok.com/@tagesschau/video/7579284006680726786', description='In Bulgarien sind Zehntausende bei regierungskritischen Protesten gegen Korruption auf die Straßen gegangen. Die Demonstration auf dem Parlamentsplatz in der Hauptstadt Sofia war die größte Kundgebung seit Jahren, die Menschen forderten mit Rufen wie „Mafia“ und „Rücktritt“ einen Regierungswechsel. #tagesschau #news #bulgarien #sofia #eu #korruption', author='tagesschau'), VideoModel(video_id='7581343969129303303', url='https://www.tiktok.com/@truthbombofficial/video/7581343969129303303', description='Reports say Russian submarines have arrived near Venezuela, creating new tension in global geopolitics. #Canada #CanadaNews #BreakingNews #Geopolitics #WorldNews', author='truthbombofficial'), VideoModel(video_id='7581829024989695287', url='https://www.tiktok.com/@newsweek/video/7581829024989695287', description='President #DonaldTrump called a female reporter "obnoxious" and a "terrible reporter" at a press conference at the White House, following a question about whether the full video of the Venezuelan boat strike would be released. #news #newsweek', author='newsweek'), VideoModel(video_id='7581879023060454669', url='https://www.tiktok.com/@reuters/video/7581879023060454669', description='Reuters published around 1.6 million photos in 2025, capturing the personal and the political, triumph and tragedy, as photographers delivered news events and daily life from 150 countries to the world. #photography #news #pictures #reuters #journalism', author='reuters'), VideoModel(video_id='7579943760428092727', url='https://www.tiktok.com/@africa_factzz/video/7579943760428092727', description='Two powerful leaders, but the focus is on Poland’s President — a man known for protecting his borders, strengthening his economy, and staying disciplined in every aspect of life. His training, his strength, and his example reflect the old standard of leadership. Here is the question: Should modern leaders return to this style, where discipline and personal example matter as much as policies? #leadershipmatters  #strongleader  #polandnews  #globalpolitics #fyp ', author='africa_factzz'), VideoModel(video_id='7579597374176251158', url='https://www.tiktok.com/@skynews/video/7579597374176251158', description="Is a Reform-Tory merger on the cards? Sam and Anne discuss if it is practical and who could be driving it behind the scenes. Listen to Politics at Sam and Anne's via the link in our bio.  #SkyNews #UK #Politics", author='skynews'), VideoModel(video_id='7580420761270258946', url='https://www.tiktok.com/@tagesschau/video/7580420761270258946', description='Jugendliche protestieren gegen den Wehrdienst, Israel nimmt am ESC teil\xa0und ein betrunkener Waschbär randaliert in Virginia. Das sind drei News der Woche.\xa0#tagesschau #nachrichten #newsderwoche', author='tagesschau')]}
