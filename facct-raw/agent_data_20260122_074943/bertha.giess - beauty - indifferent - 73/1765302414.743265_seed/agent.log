24'), VideoModel(video_id='7350432506929335595', url='https://www.tiktok.com/@makeupbymario/video/7350432506929335595', description="In case you weren't sure which Master Mattes® Eyeshadow Palette you need (it's both) 😉 #MasterMattesNeutrals #MakeupByMario", author='makeupbymario'), VideoModel(video_id='7571457432442916099', url='https://www.tiktok.com/@vivian.zhou_/video/7571457432442916099', description='Love it so much 😍 A perfect combination of lighter & darker, nude & rose, and matte & shimmery shades 🥰 Maledives, Hawaii & Necker Island are my favourites.  #makeuppalettes #eyeshadow #tartelette #nudeeyeshadow #eyemakeup ', author='vivian.zhou_'), VideoModel(video_id='7331410761903770886', url='https://www.tiktok.com/@makeupbyjessbrown/video/7331410761903770886', description='3 MUST HAVE DRUGSTORE NEUTRAL EYESHADOW PALETTES 🤑 These formulas are all stunning, and the fact that these are from the drugstore is a bonus 🔥  Please note: I am 31, female, I recently gave birth, my skin is very dry, and I live in Canada. Take these factors into consideration when going on my recommendations 🫶 • Eyeshadow palette - @NYX Cosmetics Canada ultimate warm neutrals shadow palette  • Eyeshadow palette - @Makeup Revolution fundamental reloaded shadow palette   • Eyeshadow palette - @elfcosmetics perfect 10 eyeshadow palette in shade “nude mood” #drugstore #drugstoremakeup #drugstoreeyeshadow #drugstoreeyeshadows #drugstoreeyeshadowpalette #drugstoreshadowpalette #nyxcosmetics #nyxcosmeticscanada #makeuprevolution #revolution #elfcosmetics #shoppersbeauty #walmart #notsponsored ', author='makeupbyjessbrown'), VideoModel(video_id='7347441771204349227', url='https://www.tiktok.com/@not_another_hanna/video/7347441771204349227', description='Welcome to my new series! Where I recommend makeup to elevate your looks and bring you into the editorial world. Editorial recommendations?? Haha idk still working on the name for the series. What do we think?! #beauty #makeup #makeuprecomendation